# .env.example → 복사해서 .env로 저장 후 값 채우기
# cp .env.example .env

APP_NAME=초파리 방역 분석 시스템
DEBUG=true

# Claude API 키 (https://console.anthropic.com 에서 발급)
ANTHROPIC_API_KEY=sk-ant-여기에_실제_키_입력

# DB (기본값: SQLite, 배포 시 PostgreSQL로 교체)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/flydb

# 이미지 저장 경로
UPLOAD_DIR=./uploads

# 신뢰도 임계값 (이 값보다 낮으면 사용자에게 재확인 요청)
CONFIDENCE_THRESHOLD=0.6
